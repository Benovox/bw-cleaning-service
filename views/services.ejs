<%- include('partials/header') %>
    <main class="container mt-5">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold text-primary mb-3">Professional Cleaning Services</h2>
            <p class="lead text-muted">Certified cleaning for residential homes and commercial spaces throughout Boston</p>
        </div>
        
        <div class="row mb-5 align-items-center" id="residential">
            <div class="col-md-6">
                <img src="/images/girl.jpg" class="img-fluid rounded shadow" alt="Residential Cleaning">
            </div>
            <div class="col-md-6">
                <h3 class="fw-bold mb-3">Residential Cleaning</h3>
                <p class="lead">Your home deserves professional-grade cleaning. We handle everything from routine maintenance to deep seasonal cleaning—always with attention to your family's health and your home's condition.</p>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i> Regular home maintenance cleaning</li>
                    <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i> Deep cleaning services</li>
                    <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i> Move-in/move-out cleaning</li>
                    <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i> Eco-friendly cleaning options</li>
                </ul>
            </div>
        </div>

        <div class="row mb-5 align-items-center" id="commercial">
            <div class="col-md-6 order-md-2">
                <img src="https://images.unsplash.com/photo-1737372842504-260e65e0eeab?w=900&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MTl8fGhvbWUlMjBjbGVhbmluZ3xlbnwwfHwwfHx8Mg%3D%3D" class="img-fluid rounded shadow" alt="Commercial Cleaning">
            </div>
            <div class="col-md-6 order-md-1">
                <h3 class="fw-bold mb-3">Commercial Cleaning</h3>
                <p class="lead">A clean business environment builds trust with clients and improves employee productivity. We provide reliable, professional cleaning tailored to your facility's unique needs.</p>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i> Office cleaning</li>
                    <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i> Retail space maintenance</li>
                    <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i> Industrial cleaning</li>
                    <li class="list-group-item"><i class="bi bi-check-circle-fill text-success me-2"></i> Customized cleaning schedules</li>
                </ul>
            </div>
        </div>
        
        <!--service cards-->
        <div class="row row-cols-1 row-cols-md-3 g-4">
            <div class="col">
                <div class="card h-100 shadow-lg border-0">
                    <img src="/images/room.png" class="card-img-top" alt="Residential Cleaning">
                    <div class="card-body">
                        <h5 class="card-title fw-bold"><i class="bi bi-house text-primary me-2"></i> Residential Cleaning</h5>
                        <p class="card-text">Weekly, bi-weekly, or monthly home cleaning with certified professionals. We customize our service to match your lifestyle and schedule.</p>
                    </div>
                    <div class="card-footer bg-light">
                        <a href="#residential" class="btn btn-primary">View Details</a>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card h-100 shadow-lg border-0">
                    <img src="https://images.unsplash.com/photo-1484154218962-a197022b5858?w=900&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MTZ8fGNvbW1lcmNpYWwlMjBjbGVhbmluZ3xlbnwwfHwwfHx8Mg%3D%3D" class="card-img-top" alt="Commercial Cleaning">
                    <div class="card-body">
                        <h5 class="card-title fw-bold"><i class="bi bi-building text-primary me-2"></i> Commercial Cleaning</h5>
                        <p class="card-text">Office, retail, and industrial cleaning backed by our 100% satisfaction guarantee. Dependable service, every time.</p>
                    </div>
                    <div class="card-footer bg-light">
                        <a href="#commercial" class="btn btn-primary">View Details</a>
                    </div>
                </div>
            </div>
            <div class="col">
                <div class="card h-100 shadow-lg border-0">
                    <img src="https://images.unsplash.com/photo-1708005654028-2ad581fdebe2?w=900&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MTh8fGhvdXNlJTIwY2xlYW5lZHxlbnwwfHwwfHx8Mg%3D%3D" class="card-img-top" alt="Deep Cleaning">
                    <div class="card-body">
                        <h5 class="card-title fw-bold"><i class="bi bi-stars text-primary me-2"></i> Deep Cleaning</h5>
                        <p class="card-text">Thorough, intensive cleaning targeting hard-to-reach areas. Perfect for seasonal refresh or transition cleaning.</p>
                    </div>
                    <div class="card-footer bg-light">
                        <a href="#residential" class="btn btn-primary">View Details</a>
                    </div>
                </div>
            </div>
        </div>

    </main>
<%- include('partials/footer') %>
