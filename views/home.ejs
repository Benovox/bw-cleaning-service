                    <div class="row g-4">
                        <div class="col-12">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body p-4">
                                    <div class="text-center mb-4">
                                        <i class="bi bi-house-door text-primary fs-1 mb-3"></i>
                                        <h3 class="h4 fw-bold">Standard Cleaning</h3>
                                    </div>
                                    <p class="text-muted mb-4">Perfect for maintaining a clean, comfortable living space with regular upkeep.</p>
                                    <ul class="list-unstyled">
                                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Dusting and wiping surfaces</li>
                                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Vacuuming and mopping floors</li>
                                        <li class="mb-2"><i class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Cleaning bathrooms and kitchen</li>
                                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Emptying trash bins</li>
                                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Quick tidy and organization</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body p-4">
                                    <div class="text-center mb-4">
                                        <i class="bi bi-stars text-primary fs-1 mb-3"></i>
                                        <h3 class="h4 fw-bold">Deep Cleaning</h3>
                                    </div>
                                    <p class="text-muted mb-4">Comprehensive cleaning that reaches every corner for a truly refreshed space.</p>
                                    <ul class="list-unstyled">
                                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Everything in Standard Cleaning</li>
                                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Inside appliances and cabinets</li>
                                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Baseboards and window sills</li>
                                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Behind and under furniture</li>
                                        <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i> Detailed bathroom sanitization</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="services-right">
                    <div class="service-image-wrap mb-4">
                        <img src="https://images.unsplash.com/photo-1583947215259-38e31be8751f?w=900&auto=format&fit=crop&q=60" class="img-fluid rounded shadow" alt="Standard Cleaning" loading="lazy" />
                    </div>
                    <div class="service-image-wrap">
                        <img src="https://images.unsplash.com/photo-1686178827149-6d55c72d81df?w=900&auto=format&fit=crop&q=60" class="img-fluid rounded shadow" alt="Deep Cleaning" loading="lazy" />
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- What We Clean -->
