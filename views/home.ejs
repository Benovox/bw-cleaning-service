                        <h4 class="fw-bold mb-2">Kitchen</h4>
                        <p class="text-muted">Stoves, ovens, refrigerators, cabinets, countertops, and floors</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="text-center">
                        <img src="https://images.unsplash.com/photo-1595526114035-0d45ed16cfbf?w=400&auto=format&fit=crop&q=80" class="img-fluid rounded mb-3 img-effect" alt="Bathroom Cleaning" style="height: 200px; object-fit: cover;">
