                    <h1 class="display-3 fw-bold mb-2">Residential & Commercial Experts</h1>
                    <p class="lead fs-6 mb-2">Customized cleaning solutions for homes, offices, and businesses</p>
                    <a href="/services" class="btn btn-primary btn-sm px-3 py-2 fw-bold">Explore Our Services</a>
                </div>
            </div>
            <div class="carousel-item">
                <img src="https://images.unsplash.com/photo-1595526114035-0d45ed16cfbf?w=1200&auto=format&fit=crop&q=80" class="d-block w-100" alt="Eco-Friendly Cleaning">
                <div class="carousel-caption animate__animated animate__fadeInUp">
                    <h1 class="display-3 fw-bold mb-2">Eco-Friendly & Safe Cleaning</h1>
                    <p class="lead fs-6 mb-2">Premium products that are safe for your family, pets, and the environment</p>
                    <a href="/portfolio" class="btn btn-primary btn-sm px-3 py-2 fw-bold">View Our Work</a>
                </div>
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#mainCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#mainCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
