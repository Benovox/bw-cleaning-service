<%- include('partials/header') %>
<main class="bg-light">
    <section class="py-5 text-center container">
        <div class="row py-lg-5">
            <div class="col-lg-8 mx-auto">
                <h1 class="fw-bold mb-4">Our Portfolio</h1>
                <p class="lead text-muted">See the transformative power of our professional cleaning services through our before-and-after gallery</p>
            </div>
        </div>
    </section>

    <div class="album py-5 bg-light">
        <div class="container">
            <!-- Portfolio Item 1 -->
            <div class="portfolio-item mb-5">
                <h3 class="text-center mb-4">Bedroom Transformation</h3>
                <div class="text-center mb-3">
                    <h5 class="text-success">After</h5>
                    <img src="/images/portfolio/room2.png" class="img-fluid rounded shadow" alt="Bedroom After Cleaning" style="max-width: 100%; max-height: 400px; height: auto;">
                </div>
                <div class="text-center mb-3">
                    <a href="#" class="text-primary fw-bold" onclick="toggleBefore(1); return false;">View Before</a>
                </div>
                <div id="before-1" class="before-images text-center" style="display: none;">
                    <h5 class="text-muted">Before</h5>
                    <img src="/images/portfolio/room1.png" class="img-fluid rounded shadow" alt="Bedroom Before Cleaning" style="max-width: 100%; max-height: 400px; height: auto;">
                </div>
                <p class="text-center text-muted mt-3">March 2026</p>
            </div>

            <!-- Portfolio Item 2 -->
            <div class="portfolio-item mb-5">
                <h3 class="text-center mb-4">Deep Cleaning</h3>
                <div class="text-center mb-3">
                    <h5 class="text-success">After</h5>
                    <img src="/images/portfolio/table2.png" class="img-fluid rounded shadow" alt="Table Area After Cleaning" style="max-width: 100%; max-height: 400px; height: auto;">
                </div>
                <div class="text-center mb-3">
                    <a href="#" class="text-primary fw-bold" onclick="toggleBefore(2); return false;">View Before</a>
                </div>
                <div id="before-2" class="before-images text-center" style="display: none;">
                    <h5 class="text-muted">Before</h5>
                    <img src="/images/portfolio/table1.png" class="img-fluid rounded shadow" alt="Table Area Before Cleaning" style="max-width: 100%; max-height: 400px; height: auto;">
                </div>
                <p class="text-center text-muted mt-3">March 2026</p>
            </div>

            <!-- Portfolio Item 3 -->
            <div class="portfolio-item mb-5">
                <h3 class="text-center mb-4">Kitchen Deep Clean</h3>
                <div class="text-center mb-3">
                    <h5 class="text-success">After</h5>
                    <img src="/images/portfolio/kitchen after.png" class="img-fluid rounded shadow" alt="Kitchen After Cleaning" style="max-width: 100%; max-height: 400px; height: auto;">
                </div>
                <div class="text-center mb-3">
                    <a href="#" class="text-primary fw-bold" onclick="toggleBefore(3); return false;">View Before</a>
                </div>
                <div id="before-3" class="before-images text-center" style="display: none;">
                    <h5 class="text-muted">Before</h5>
                    <img src="/images/portfolio/kitchen before.png" class="img-fluid rounded shadow" alt="Kitchen Before Cleaning" style="max-width: 100%; max-height: 400px; height: auto;">
                </div>
                <p class="text-center text-muted mt-3">March 2026</p>
            </div>

            <!-- Portfolio Item 4 -->
            <div class="portfolio-item mb-5">
                <h3 class="text-center mb-4">Office Space Cleaning</h3>
                <div class="text-center mb-3">
                    <h5 class="text-success">After</h5>
                    <img src="/images/portfolio/Office after.png" class="img-fluid rounded shadow" alt="Office After Cleaning" style="max-width: 100%; max-height: 400px; height: auto;">
                </div>
                <div class="text-center mb-3">
                    <a href="#" class="text-primary fw-bold" onclick="toggleBefore(4); return false;">View Before</a>
                </div>
                <div id="before-4" class="before-images text-center" style="display: none;">
                    <h5 class="text-muted">Before</h5>
                    <img src="/images/portfolio/Office before.png" class="img-fluid rounded shadow" alt="Office Before Cleaning" style="max-width: 100%; max-height: 400px; height: auto;">
                </div>
                <p class="text-center text-muted mt-3">March 2026</p>
            </div>
        </div>
    </div>

    <script>
        function toggleBefore(id) {
            const beforeDiv = document.getElementById('before-' + id);
            if (beforeDiv.style.display === 'none' || beforeDiv.style.display === '') {
                beforeDiv.style.display = 'block';
            } else {
                beforeDiv.style.display = 'none';
            }
        }
    </script>
</main>
<%- include('partials/footer') %>
