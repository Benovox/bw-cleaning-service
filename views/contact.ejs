<%- include('partials/header') %>
<main class="container mt-5">
    <h2 class="mb-1">Get Your Free Cleaning Quote</h2>
    <p class="text-muted mb-4">No obligation. No surprises. Just a fair quote based on your specific needs. We'll contact you within 24 hours.</p>

    <% if (success && success === 'true') { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Quote Request Received!</strong> Thanks for choosing B&W Cleaning. We'll review your details and contact you shortly with a personalized quote.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% } %>

    <% if (error && error === 'true') { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Oops!</strong> We encountered an issue sending your request. Please try again or call us at 857-385-2270.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    <% } %>

    <div class="row">
        <div class="col-lg-7 col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <p class="text-muted mb-4"><small>All fields marked with <strong>*</strong> are required.</small></p>
                    <form action="/contact" method="POST" novalidate>
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">Full Name*</label>
                                <input type="text" name="name" class="form-control" required>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Phone*</label>
                                <input type="tel" name="phone" class="form-control" required>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Email*</label>
                                <input type="email" name="email" class="form-control" required>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Service Type*</label>
                                <select name="serviceType" class="form-select" required>
                                    <option value="">Choose one...</option>
                                    <option value="Standard Cleaning">Standard Cleaning</option>
                                    <option value="Deep Cleaning">Deep Cleaning</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Frequency</label>
                                <select name="frequency" class="form-select">
                                    <option value="One-time">One-time</option>
                                    <option value="Weekly">Weekly</option>
                                    <option value="Bi-weekly">Bi-weekly</option>
                                    <option value="Monthly">Monthly</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Number of Bedrooms</label>
                                <select name="bedrooms" class="form-select">
                                    <option value="Studio">Studio</option>
                                    <option value="1 Bedroom">1 Bedroom</option>
                                    <option value="2 Bedrooms">2 Bedrooms</option>
                                    <option value="3 Bedrooms">3 Bedrooms</option>
                                    <option value="4+ Bedrooms">4+ Bedrooms</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Number of Bathrooms</label>
                                <select name="bathrooms" class="form-select">
                                    <option value="1 Bathroom">1 Bathroom</option>
                                    <option value="2 Bathrooms">2 Bathrooms</option>
                                    <option value="3 Bathrooms">3 Bathrooms</option>
                                    <option value="4+ Bathrooms">4+ Bathrooms</option>
                                </select>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Notes / Message (optional)</label>
                                <textarea name="message" class="form-control" rows="5" placeholder="Any special notes or details."></textarea>
                            </div>

                            <div class="col-12 text-end">
                                <button type="submit" id="submitBtn" class="btn btn-primary">Send Quote Request</button>
                            </div>
                        </div>
                    </form>
                    <script>
                        (function() {
                            const form = document.querySelector('form[action="/contact"][method="POST"]');
                            const submitBtn = document.getElementById('submitBtn');

                            if (!form || !submitBtn) return;

                            form.addEventListener('submit', function(event) {
                                if (!form.checkValidity()) {
                                    return;
                                }

                                submitBtn.disabled = true;
                                submitBtn.innerText = 'Sending...';
                            });
                        })();
                    </script>
                </div>
            </div>
        </div>

        <div class="col-lg-5 col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h4 class="card-title mb-4">Get in Touch</h4>
                    <div class="mb-4">
                        <div class="d-flex align-items-start mb-3">
                            <i class="bi bi-geo-alt-fill text-primary me-3 mt-1"></i>
                            <div>
                                <strong>Location</strong><br>
                                <span class="text-muted">123 Howard Ave, Dorchester, MA</span>
                            </div>
                        </div>
                        <div class="d-flex align-items-start mb-3">
                            <i class="bi bi-telephone-fill text-primary me-3 mt-1"></i>
                            <div>
                                <strong>Phone</strong><br>
                                <span class="text-muted"><a href="tel:857-385-2270" class="text-decoration-none">857-385-2270</a></span>
                            </div>
                        </div>
                        <div class="d-flex align-items-start mb-4">
                            <i class="bi bi-envelope-fill text-primary me-3 mt-1"></i>
                            <div>
                                <strong>Email</strong><br>
                                <span class="text-muted"><a href="mailto:leiteruiz37@gmail.com" class="text-decoration-none">leiteruiz37@gmail.com</a></span>
                            </div>
                        </div>
                    </div>
                    <hr>
                    <h5 class="fw-bold mb-3">Our Hours</h5>
                    <p class="text-muted mb-2"><strong>Monday - Friday:</strong> 8:00 AM - 6:00 PM</p>
                    <p class="text-muted"><strong>Saturday:</strong> 9:00 AM - 5:00 PM</p>
                    <p class="text-muted"><em>Closed Sundays</em></p>
                    <div class="alert alert-info mt-4" role="alert">
                        <strong>Guarantee:</strong> We're confident you'll love our work. If you're not 100% satisfied, we'll make it right.
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
<%- include('partials/footer') %>
